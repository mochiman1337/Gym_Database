<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="EmployeeDashboard">
  <grid id="27dc6" binding="employeePanel" layout-manager="GridLayoutManager" row-count="2" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="2bfd7" class="javax.swing.JLabel" binding="welcomeLabel">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="&quot;Welcome, [Name]&quot;"/>
        </properties>
      </component>
      <tabbedpane id="6fd64" binding="scheduleTab">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="2" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false">
            <preferred-size width="200" height="200"/>
          </grid>
        </constraints>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="d2718" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Master Schedule"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <scrollpane id="33db0">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="2dde" class="javax.swing.JTable" binding="masterScheduleTable">
                    <constraints/>
                    <properties/>
                  </component>
                </children>
              </scrollpane>
              <component id="6361e" class="javax.swing.JButton" binding="createClassButton">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Schedule Next Class"/>
                </properties>
              </component>
              <component id="6f059" class="javax.swing.JButton" binding="cancelClassButton">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Cancel Selected Class"/>
                </properties>
              </component>
            </children>
          </grid>
          <grid id="14893" binding="membersTab" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Member Management"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <scrollpane id="f13c6">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="7" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="f0778" class="javax.swing.JTable" binding="membersTable">
                    <constraints/>
                    <properties/>
                  </component>
                </children>
              </scrollpane>
              <component id="7ca70" class="javax.swing.JButton" binding="cancelMembershipButton">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Cancel Membership"/>
                </properties>
              </component>
            </children>
          </grid>
          <grid id="92299" binding="adminTab" layout-manager="GridLayoutManager" row-count="3" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Admin Tools"/>
            </constraints>
            <properties/>
            <border type="none"/>
            <children>
              <component id="a16a8" class="javax.swing.JButton" binding="createEmployeeButton">
                <constraints>
                  <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Register New Employee"/>
                </properties>
              </component>
              <component id="af893" class="javax.swing.JButton" binding="resetPasswordButton">
                <constraints>
                  <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Force Password Reset"/>
                </properties>
              </component>
              <component id="96074" class="javax.swing.JButton" binding="deleteUserButton">
                <constraints>
                  <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
                </constraints>
                <properties>
                  <text value="Delete User Account"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </tabbedpane>
      <component id="88c02" class="javax.swing.JButton" binding="logoutButton">
        <constraints>
          <grid row="0" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="4" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Log Out"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
